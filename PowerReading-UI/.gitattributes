# Enforce LF line endings for source files
*.js     text eol=lf
*.jsx    text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.md     text eol=lf
*.json   text eol=lf

# Auto-detect text files and normalize line endings
* text=auto

# Binary files (no line ending conversion)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.svg    binary
